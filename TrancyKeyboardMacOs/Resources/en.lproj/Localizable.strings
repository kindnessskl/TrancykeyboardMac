/* GuideData */
"Guide_Title_SmartPath" = "Smart Path";
"Guide_Content_SmartPath" = "Intention: \"中文\". You can type in 4 ways:\n\n• Exact Pinyin: zhong wen\n• Initials (Jianpin): zh w\n• Mixed: zh wen or zhong w\n\nAll yield \"中文\". Smart path applies to all words.";
"Guide_Title_FuzzyPinyin" = "Fuzzy Pinyin";
"Guide_Content_FuzzyPinyin" = "Enables \"zh-z\" conversion. For example, typing \"zong wen\" yields both \"zong wen\" and \"zhong wen\".\n\nWhen combining \"zh-z\" and \"an-ang\", typing \"zong zhang\" yields 4 paths (zong zhan, zong zhang, zhong zhan, zhong zhang)";
"Guide_Title_Correction" = "Correction";
"Guide_Content_Correction" = "Auto-corrects pinyin positions (e.g., \"hzi\" to \"zhi\") and completes vowels (e.g., \"yon\" to \"yong\"). Key correction finds valid pinyin near your touch (e.g., \"yoi\" to \"you\").";
"Guide_Title_DualCandidate" = "Dual Mode";
"Guide_Content_DualCandidate" = "Cn/En mode shows Chinese and English. English Search reverse-looks up Chinese from English input. Expand candidate bar to sort by frequency, pinyin, or strokes.";
"Guide_Title_WordManagement" = "Word Management";
"Guide_Content_WordManagement" = "Automatically learns your vocabulary. For example, if \"Trancy Keyboard\" isn't in the dictionary, selecting \"Trancy\" and \"Keyboard\" in sequence will record it for future use.\n\nAlgorithms automatically combine unknown phrases based on frequency, learning your typing habits for smarter candidates.\n\nYou can edit, correct, add, or delete these words in the main app.";
"Guide_Content_WordManagement" = "Automatically learns your vocabulary. For example, if \"Trancy Keyboard\" isn't in the dictionary, selecting \"Trancy\" and \"Keyboard\" in sequence will record it for future use.\n\nAlgorithms automatically combine unknown phrases based on frequency, learning your typing habits for smarter candidates.\n\nYou can edit, correct, add, or delete these words in the main app. \n\niCloud synchronization\nSupports the two-way synchronization function of mac and ios. The word selection you enter on the mac will appear on the ios end after the synchronization is turned on, generating the entries of learning records; the words newly created on the ios end will also appear on the mac end.";
"Guide_Title_Tips" = "Tips";
"Guide_Content_Tips" = "Long-press Delete to clear input. Use Split button to manually segment pinyin (e.g., \"ke n\" for \"可能\"). Slide down candidates to expand and filter.";
"Guide_Title_Custom" = "Personalization";
"Guide_Content_Custom" = "Customize colors, keyboard height, sounds, haptics, and font sizes to your liking.";

"Guide_Title_eng" = "English & Fuzzy Match";
"Guide_Content_eng" = "Search English words alongside Pinyin. Typing \"she\" queries both English words and Pinyin candidates.\n\nFuzzy English Match predicts intent based on approximate pronunciation or key proximity. Even with typos, it finds the right word. Example: \"frind\" matches \"friend\".\n\nVector-based intent guessing: typing \"woke\" suggests \"wake\", \"work\", \"week\".";

"Guide_Title_emoji" = "Emoji & Symbol Search";
"Guide_Content_emoji" = "Search for emojis and symbols by typing related Chinese keywords. They appear directly in the candidate bar for selection.";

"Guide_Title_slideinput" = "Glide Typing";
"Guide_Content_slideinput" = "Glide across the keyboard to input words effortlessly. For example, sliding over \"yuio\" identifies \"you\".\n\nNoise tolerance allows for up to 2 error characters and ignores vowel order (e.g., \"kuia\", \"kaui\", \"kiua\" all correct to \"kuai\").\n\nPinyin ending in \"n\" or \"g\" has higher tolerance, ignoring most accidental touches during the glide.";
